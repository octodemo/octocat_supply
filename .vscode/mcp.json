{
  "inputs": [
    {
      "id": "github_token",
      "type": "promptString",
      "description": "GitHub Personal Access Token",
      "password": true
    },
    {
      "id": "atlassian_url",
      "type": "promptString",
      "description": "Atlassian base URL (e.g. https://yourcompany.atlassian.net)"
    },
    {
      "id": "atlassian_email",
      "type": "promptString",
      "description": "Atlassian account e-mail address"
    },
    {
      "id": "atlassian_token",
      "type": "promptString",
      "description": "Atlassian API token",
      "password": true
    }
  ],
  "servers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "github": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${input:github_token}"
      }
    },
    "github-remote": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "X-MCP-Toolsets": "actions, code_security, dependabot, discussions, issues, orgs, projects, pull_requests, repos, secret_protection, security_advisories, copilot, copilot_spaces"
      }
    },
    "Azure MCP Server": {
      "command": "npx",
      "args": [
        "-y",
        "@azure/mcp@latest",
        "server",
        "start"
      ]
    },
    "atlassian": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "-p",
        "jsdom",
        "-p",
        "mcp-atlassian",
        "mcp-atlassian"
      ],
      "env": {
        "ATLASSIAN_BASE_URL": "${input:atlassian_url}",
        "ATLASSIAN_EMAIL": "${input:atlassian_email}",
        "ATLASSIAN_API_TOKEN": "${input:atlassian_token}"
      }
    }
  }
}
